<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.LibrarianController">
    <!-- Sidebar -->
    <VBox prefWidth="250.0" style="-fx-background-color: #1F2937;">
        <VBox alignment="CENTER" prefHeight="100.0" spacing="10.0">
            <Label text="LIB-SYSTEM" textFill="WHITE">
                <font><Font name="System Bold" size="24.0" /></font>
            </Label>
            <Separator opacity="0.1" prefWidth="200.0">
                <VBox.margin><Insets left="30.0" right="30.0" /></VBox.margin>
            </Separator>
        </VBox>

        <VBox spacing="5.0" style="-fx-padding: 10 15;">
            <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 0 0 10 10;" text="CHỨC NĂNG CHÍNH" textFill="#9CA3AF" />
            <Button alignment="BASELINE_LEFT" maxWidth="Infinity" prefHeight="45.0" style="-fx-background-color: #374151; -fx-text-fill: white; -fx-background-radius: 8;" text="📦  Quản Lý Kho Sách" />
            <!-- Giữ nguyên Button trống như bản cũ -->
            <Button alignment="BASELINE_LEFT" maxWidth="Infinity" prefHeight="45.0" style="-fx-background-color: transparent; -fx-text-fill: #9CA3AF;" />
        </VBox>

        <Region VBox.vgrow="ALWAYS" />
        <VBox alignment="CENTER" style="-fx-padding: 20;" />
    </VBox>

    <VBox spacing="0.0" HBox.hgrow="ALWAYS">
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: white; -fx-padding: 0 30;">
            <effect><DropShadow blurType="GAUSSIAN" height="1.0" offsetY="1.0" radius="0.0" width="0.0"><color><Color opacity="0.1" /></color></DropShadow></effect>
            <Label text="QUẢN TRỊ VIÊN THƯ VIỆN" textFill="#111827">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="10.0">
                <Label fx:id="lblTotalLoaned" style="-fx-background-color: #F59E0B; -fx-text-fill: white; -fx-padding: 6 15; -fx-background-radius: 20; -fx-font-weight: bold;" text="Sách đang mượn: 0" />
            </HBox>
        </HBox>

        <TabPane fx:id="tabPaneMain" style="-fx-padding: 20;" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            <tabs>
                <!-- Tab 1: KHO SÁCH -->
                <Tab text="  📦 KHO SÁCH  ">
                    <HBox spacing="20.0" style="-fx-padding: 15 0 0 0;">
                        <!-- Form Cập Nhật -->
                        <VBox prefWidth="340.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12;">
                            <Label text="CẬP NHẬT THÔNG TIN" textFill="#374151">
                                <font><Font name="System Bold" size="14.0" /></font>
                            </Label>
                            <VBox spacing="12.0">
                                <TextField fx:id="txtBookId" editable="false" prefHeight="40" promptText="ID Sách (Tự động)" style="-fx-background-color: #F9FAFB; -fx-border-color: #D1D5DB; -fx-border-radius: 5;" />
                                <TextField fx:id="txtTitle" prefHeight="40" promptText="Tiêu đề sách" style="-fx-border-color: #D1D5DB; -fx-border-radius: 5;" />
                                <TextField fx:id="txtAuthor" prefHeight="40" promptText="Tác giả" style="-fx-border-color: #D1D5DB; -fx-border-radius: 5;" />
                                <TextField fx:id="txtQuantity" prefHeight="40" promptText="Số lượng" style="-fx-border-color: #D1D5DB; -fx-border-radius: 5;" />
                                <ComboBox fx:id="cbCategory" prefHeight="40" prefWidth="Infinity" promptText="Thể loại" style="-fx-background-color: white; -fx-border-color: #D1D5DB; -fx-border-radius: 5;" />
                                <ComboBox fx:id="cbPublisher" prefHeight="40" prefWidth="Infinity" promptText="Nhà xuất bản" style="-fx-background-color: white; -fx-border-color: #D1D5DB; -fx-border-radius: 5;" />
                            </VBox>
                            <HBox spacing="10.0" style="-fx-padding: 5 0 0 0;">
                                <Button maxWidth="Infinity" onAction="#addBookAction" prefHeight="40.0" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="THÊM" HBox.hgrow="ALWAYS" />
                                <Button maxWidth="Infinity" onAction="#deleteBookAction" prefHeight="40.0" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="XÓA" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <Button maxWidth="Infinity" onAction="#resetFormAction" prefHeight="35.0" style="-fx-background-color: #6B7280; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" text="LÀM MỚI FORM" />
                        </VBox>

                        <!-- Table -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                            <TableView fx:id="tblBooks" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                                    <TableColumn fx:id="colTitle" prefWidth="200" text="Tiêu đề" />
                                    <TableColumn fx:id="colAuthor" prefWidth="130" text="Tác giả" />
                                    <TableColumn fx:id="colQuantity" prefWidth="60" text="SL" />
                                    <TableColumn fx:id="colCat" prefWidth="120" text="Thể loại" />
                                    <TableColumn fx:id="colPub" prefWidth="120" text="Nhà xuất bản" />
                                </columns>
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                            </TableView>
                        </VBox>
                    </HBox>
                </Tab>

                <!-- Tab 2: LỊCH SỬ -->
                <Tab text="  📋 LỊCH SỬ &amp; TRẢ SÁCH  ">
                    <VBox spacing="15.0" style="-fx-padding: 15 0 0 0;">
                        <TableView fx:id="tblHistory" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-padding: 5;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colHistoryUser" prefWidth="150" text="Thành viên" />
                                <TableColumn fx:id="colHistoryBook" prefWidth="250" text="Sách mượn" />
                                <TableColumn fx:id="colHistoryDate" prefWidth="150" text="Ngày giao dịch" />
                                <TableColumn fx:id="colHistoryStatus" prefWidth="120" text="Trạng thái" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER_RIGHT">
                            <Button onAction="#handleReturnBook" prefHeight="45" prefWidth="250" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="XÁC NHẬN HOÀN TRẢ SÁCH" />
                        </HBox>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </VBox>
</HBox>